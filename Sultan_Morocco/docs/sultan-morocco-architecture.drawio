  <diagram id="hotel-sequence" name="Hotel data flow">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0s"/>
        <mxCell id="1s" parent="0s"/>

        <mxCell id="hs-title" value="&lt;b&gt;Hotel list &amp; map — request sequence&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=13;" vertex="1" parent="1s">
          <mxGeometry x="200" y="20" width="500" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="hs1" value="Browser&#xa;(hotels or map page)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1" vertex="1" parent="1s">
          <mxGeometry x="60" y="80" width="140" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="hs2" value="Laravel&#xa;GET /api/hotels&#xa;?offset&amp;limit&amp;sort" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1s">
          <mxGeometry x="280" y="80" width="180" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="hs3" value="Validate query&#xa;Read config&#xa;services.xotelo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1s">
          <mxGeometry x="520" y="80" width="160" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="hs4" value="Xotelo&#xa;GET …/list&#xa;location_key" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;shadow=1" vertex="1" parent="1s">
          <mxGeometry x="720" y="80" width="140" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="hs-e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1s" source="hs1" target="hs2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="hs-e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1s" source="hs2" target="hs3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="hs-e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1s" source="hs3" target="hs4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="hs5" value="200 JSON → same body to browser&#xa;502 if Xotelo fails • 503 if key missing" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=10;dashed=1;dashPattern=6 6;" vertex="1" parent="1s">
          <mxGeometry x="280" y="200" width="420" height="48" as="geometry"/>
        </mxCell>
        <mxCell id="hs-e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;endArrow=open;endFill=0;strokeColor=#b85450;" edge="1" parent="1s" source="hs4" target="hs5">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="790" y="190"/>
              <mxPoint x="490" y="190"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="hs-e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;endArrow=open;endFill=0;strokeColor=#6c8ebf;" edge="1" parent="1s" source="hs5" target="hs1">
