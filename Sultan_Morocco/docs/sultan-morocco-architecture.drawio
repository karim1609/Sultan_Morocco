        </mxCell>
        <mxCell id="me2" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1m" source="m2" target="m3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="me3" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1m" source="m3" target="m4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="m5" value="POST body → Message::create(sender_id = auth id)&#xa;GET thread → mark others' messages read_at" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff9e6;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1m">
          <mxGeometry x="180" y="220" width="480" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="m6" value="User B sees inbox + thread (same auth rules)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1m">
          <mxGeometry x="220" y="300" width="360" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="me4" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;endArrow=classic;strokeColor=#b85450;" edge="1" parent="1m" source="m4" target="m6">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="760" y="280"/>
              <mxPoint x="400" y="280"/>
