        </mxCell>

        <mxCell id="hs6" value="JS renders cards / Leaflet markers&#xa;(name, geo, price, rating, image, url)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1s">
          <mxGeometry x="60" y="290" width="800" height="44" as="geometry"/>
