          <mxGeometry x="80" y="190" width="400" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="p1" value="/  →  welcome.blade.php" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="lane-public">
          <mxGeometry x="20" y="45" width="160" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="/hotels → HotelController@index" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="lane-public">
