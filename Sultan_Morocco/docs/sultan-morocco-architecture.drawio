  <diagram id="messaging" name="Messaging flow">
    <mxGraphModel dx="1000" dy="640" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0m"/>
        <mxCell id="1m" parent="0m"/>

        <mxCell id="mt" value="&lt;b&gt;Direct messaging (1:1)&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=13;" vertex="1" parent="1m">
